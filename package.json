{
  "name": "firstregistrars-buildwise-workspace",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "buildwise",
    "lib/*"
  ],
  "scripts": {
    "build": "npm --workspace buildwise run build",
    "dev": "npm --workspace buildwise run dev",
    "serve": "npm --workspace buildwise run serve",
    "typecheck": "npm --workspace buildwise run typecheck"
  }
}
